{
	"name": "promised-pipes",
	"version": "0.1.0",
	"description": "Elegant async pipelines that flow, transform, and recover without the noise.",
	"license": "MIT",
	"author": "Prakhar-Srivastava",
	"type": "module",
	"main": "./pipe.mjs",
	"module": "./pipe.mjs",
	"types": "./pipe.d.ts",
	"exports": {
		".": {
			"import": "./pipe.mjs",
			"types": "./pipe.d.ts"
		}
	},
	"engines": {
		"node": ">=18.0.0"
	},
	"scripts": {
		"test": "node --test tests/pipe.test.mjs",
		"test:watch": "node --test --watch tests/pipe.test.mjs",
		"build": "mkdir -p dist && esbuild pipe.mjs --bundle --minify --sourcemap --format=esm --target=es2020 --platform=browser --outfile=dist/pipe.min.mjs",
		"build:iife": "mkdir -p dist && esbuild pipe.mjs --bundle --minify --sourcemap --format=iife --target=es2018 --platform=browser --global-name=Pipe --outfile=dist/pipe.global.js",
		"build:wasm": "mkdir -p dist && esbuild targets/pipe.wasm.js --bundle --minify --format=esm --outfile=dist/pipe.wasm.mjs --target=es2020 --platform=neutral",
		"build:all": "rm -rf dist && npm run build && npm run build:iife && npm run build:wasm"
	},
	"keywords": [
		"promise",
		"pipe",
		"monad",
		"async",
		"pipeline",
		"functional",
		"thenable",
		"retry",
		"timeout",
		"observable"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/Prakhar-Srivastava/promised-pipes"
	},
	"devDependencies": {
		"esbuild": "^0.28.0"
	}
}
